# Sample environment file for compare_readarr.py
#
# Copy this to ".env" and edit the values for your setup:
#     cp sample.env .env
#
# The script loads ".env" automatically (override the path with --env-file,
# or disable loading entirely with --no-env-file).
#
# Precedence: an explicit CLI flag beats a real shell env var, which beats a
# value from this file. So a value set here is used only when it isn't already
# set in the environment or passed on the command line.

# ---- PostgreSQL connection (standard libpq PG* variables) -------------------
PGHOST=localhost
PGPORT=5432
PGDATABASE=readarr-main
PGUSER=readarr
# Leave PGPASSWORD unset to use ~/.pgpass instead, if you prefer.
PGPASSWORD=changeme

# ---- Scan / comparison options ----------------------------------------------
# Filesystem root to scan for book files.
ROOT=/data/media/books/spoken

# Extra extensions to treat as book content, comma-separated (added to the
# built-in defaults). Example: EXT=.m4b,.mp3
# EXT=

# Consider every file on disk, ignoring the extension filter (true/false).
# ALL_FILES=false

# Also write a machine-readable report to this JSON path.
# JSON=/tmp/readarr_compare.json

# Only print summary counts, not individual paths (true/false).
# QUIET=false

# Stop after reporting this many files in each category (for testing).
# Summary counts still reflect the true totals. Use 0 for no limit. Default 10.
# LIMIT=10

# Rewrite DB path prefixes to their on-disk equivalents before comparing.
# Needed when Readarr runs in a container and stores a different mount path
# than the host sees. Format: DB_PREFIX=DISK_PREFIX. Separate multiple
# entries with ';'. Example (Readarr sees /books, host has the full path):
# PATH_MAP=/books=/data/media/books/spoken

# ---- MISMATCH check ---------------------------------------------------------
# Flags books whose associated file path doesn't match the book's author/title
# (the wrong file appears to be linked). Set to true to disable entirely.
# NO_MISMATCH_CHECK=false

# Compare author folders only and ignore title differences (titles are fuzzier
# and can produce false positives in some libraries). true/false.
# NO_TITLE_CHECK=false

# List files whose folder matches one of the book's edition titles but not the
# current book title (a benign side effect of Readarr not renaming files after
# an edition-title change). These are NOT counted as mismatches. true/false.
# SHOW_EDITION_MATCHES=false

# Write a reviewable SQL script that unlinks every MISMATCH (DELETE FROM
# "BookFiles" ...), to disassociate files without deleting them from disk.
# Review and apply it yourself. Covers all mismatches, ignoring LIMIT.
# EMIT_SQL=unlink.sql

# Write a shell script of 'cp -r' commands that copy each mismatched book's
# folder into the manual-import staging dir (COPY_DEST) for re-import.
# Originals are left in place. Covers all mismatches, ignoring LIMIT.
# EMIT_COPY=copy.sh

# Destination directory for the EMIT_COPY commands.
# COPY_DEST=/data/media/Download/manual-import/

# Command used by EMIT_COPY: cp or rsync. rsync supports a real progress bar
# (combine with COPY_PROGRESS).
# COPY_TOOL=cp

# Show progress in EMIT_COPY (true/false): 'cp -rv' prints each file; with
# COPY_TOOL=rsync it adds '--info=progress2' for a percentage bar.
# COPY_PROGRESS=false
